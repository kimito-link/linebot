{
  "$schema": "./bot.config.schema.json",
  "defaultProject": "ai-shain-link",
  "llm": {
    "provider": "groq",
    "model": "llama-3.3-70b-versatile",
    "apiKeySecretName": "GROQ_API_KEY",
    "maxOutputTokens": 500,
    "timeoutMs": 8000,
    "dailyCallBudget": 800,
    "chain": [
      { "provider": "groq", "model": "llama-3.3-70b-versatile", "timeoutMs": 8000 },
      { "provider": "gemini", "model": "gemini-2.5-flash-lite", "timeoutMs": 10000 },
      { "provider": "workers-ai", "model": "@cf/meta/llama-3.3-70b-instruct-fp8-fast", "timeoutMs": 8000 }
    ],
    "vision": {
      "enabled": true,
      "maxDescriptionTokens": 250,
      "chain": [
        { "provider": "groq", "model": "qwen/qwen3.6-27b", "timeoutMs": 10000 },
        { "provider": "gemini", "model": "gemini-2.5-flash-lite", "timeoutMs": 10000 }
      ]
    },
    "video": {
      "enabled": true,
      "model": "gemini-2.5-flash-lite",
      "timeoutMs": 22000,
      "maxDescriptionTokens": 250,
      "maxInputBytes": 15728640
    },
    "audio": {
      "enabled": true,
      "model": "gemini-2.5-flash-lite",
      "timeoutMs": 28000,
      "maxDescriptionTokens": 250,
      "maxInputBytes": 15728640
    }
  },
  "line": {
    "channelSecretName": "LINE_CHANNEL_SECRET",
    "channelAccessTokenSecretName": "LINE_CHANNEL_ACCESS_TOKEN"
  },
  "escalation": {
    "mode": "conversation-inbox"
  },
  "cache": {
    "enabled": true,
    "ttlHours": 72
  },
  "retrieval": {
    "topK": 3,
    "minScore": 0.0
  },
  "urlContext": {
    "enabled": true,
    "timeoutMs": 6000,
    "maxContentBytes": 524288,
    "maxExtractChars": 2000
  },
  "projects": {
    "ai-shain-link": { "knowledgePack": "./knowledge-packs/ai-shain" },
    "soushin-suggest": { "knowledgePack": "./knowledge-packs/soushin-suggest" },
    "henshin-hisho": { "knowledgePack": "./knowledge-packs/henshin-hisho" }
  }
}
